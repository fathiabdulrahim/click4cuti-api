# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/click4cuti_development

# Redis & Sidekiq
REDIS_URL=redis://localhost:6379/0

# Devise JWT
DEVISE_JWT_SECRET_KEY=your-secret-key-here-generate-with-rails-secret
DEVISE_MAILER_FROM=noreply@click4cuti.com

# AWS S3 (Active Storage)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_BUCKET=click4cuti-uploads
AWS_REGION=ap-southeast-1

# CORS
CORS_ORIGIN_STAGING=https://staging.click4cuti.com
CORS_ORIGIN_PRODUCTION=https://app.click4cuti.com

# Sentry (optional)
SENTRY_DSN=

# Rails
RAILS_MASTER_KEY=your-master-key
SECRET_KEY_BASE=your-secret-key-base
RAILS_ENV=development
